# Port where the panel will be exposed
PANEL_PORT=3090
PANEL_CONTROL_MODE=portainer

# Minecraft target server
MC_HOST=192.168.50.197
MC_PORT=25565
MC_PROTOCOL_VERSION=767
MC_TIMEOUT_MS=5000

# RCON (required for players/commands)
RCON_ENABLED=true
RCON_HOST=192.168.50.197
RCON_PORT=25575
RCON_PASSWORD=CHANGE_ME
RCON_TIMEOUT_MS=5000

# Portainer API connection
PORTAINER_ENABLED=true
PORTAINER_BASE_URL=http://192.168.50.197:9000
PORTAINER_AUTH_TYPE=apiKey
PORTAINER_API_KEY=CHANGE_ME
PORTAINER_BEARER_TOKEN=
PORTAINER_ENDPOINT_ID=1
PORTAINER_CONTAINER_ID=EyedComun-Pruebas
PORTAINER_TIMEOUT_MS=8000

# Optional file explorer/logs (host path must exist)
FILES_ENABLED=false
FILES_ROOT_DIRECTORY=/minecraftpruebas/data
FILES_LOGS_PATH=/minecraftpruebas/data/logs/latest.log
